# LLM backend
LLM_PROVIDER=openai-compatible
OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_MODEL=your-model-name
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=unused

# Switch to Ollama instead if needed
# LLM_PROVIDER=ollama
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5-coder:14b-instruct
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Qwen (DB query sub-agent, falls back to OPENAI_* if not set)
# QWEN_BASE_URL=https://your-qwen-endpoint/v1
# QWEN_MODEL=your-qwen-model-name
# QWEN_API_KEY=your-qwen-api-key

# TypeDB
TYPEDB_ADDRESS=127.0.0.1:1729
TYPEDB_DATABASE=compensation_regulations

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j
NEO4J_VECTOR_ENABLED=0
NEO4J_VECTOR_INDEX_NAME=search_target_embeddings
NEO4J_VECTOR_LABEL=검색대상
NEO4J_VECTOR_PROPERTY=검색벡터
NEO4J_VECTOR_DIMENSIONS=1536
NEO4J_VECTOR_TOP_K=6
NEO4J_VECTOR_MIN_SCORE=0.72
NEO4J_VECTOR_SIMILARITY=cosine
NEO4J_VECTOR_RERANK_TOPIC_WEIGHT=0.08
NEO4J_VECTOR_RERANK_ENTITY_WEIGHT=0.10
NEO4J_VECTOR_RERANK_KEYWORD_WEIGHT=0.02
NEO4J_VECTOR_RERANK_KIND_BONUS=0.18
NEO4J_VECTOR_RERANK_ARTICLE_BONUS=0.24
NEO4J_VECTOR_RERANK_MISS_PENALTY=0.05